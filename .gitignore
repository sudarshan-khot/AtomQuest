# ============================================================
# AtomQuest — .gitignore
# ============================================================

# ── Kiro / IDE ───────────────────────────────────────────────
.kiro/
.vscode/
.idea/
*.suo
*.user

# ── Scratch / notes ──────────────────────────────────────────
use.txt

# ── Python / Django ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
media/

# Environment variables
backend/.env
.env
.env.local
.env.*.local

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
pytest.xml

# ── Node / Frontend ──────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Docker ───────────────────────────────────────────────────
# (docker-compose files are intentionally tracked)

# ── Logs ─────────────────────────────────────────────────────
backend/logs/*.log
logs/

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.swp
*.swo
*~
.cache/
